#: hdrcalibrator.cpp:149 Main.qml:15
#, kde-format
msgctxt "@title:window"
msgid "HDR Calibration"
msgstr "Calibration HDR"

#: Main.qml:187 Main.qml:365
#, kde-format
msgctxt "@action:button"
msgid "Next"
msgstr "Proxime"

#: Main.qml:194 Main.qml:371
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Switches to the next page"
msgstr "Passa al proxime pagina"

#: Main.qml:198 Main.qml:375 Main.qml:475
#, kde-format
msgctxt "@action:button"
msgid "Cancel"
msgstr "Cancella"

#: Main.qml:201 Main.qml:378 Main.qml:478
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Cancels the calibration process"
msgstr "Cancella le processo de calibration"

#: Main.qml:210
#, kde-format
msgid ""
"To determine the maximum brightness of the screen, adjust the slider until "
"the logo is barely visible"
msgstr ""
"Per determinar le maxime brillantia del shermo, accomoda le glissator usque "
"le logo es apena visibile  "

#: Main.qml:389
#, kde-format
msgid ""
"Configure how bright “100%” on the normal brightness slider should be. Make "
"it as bright as you'd ever use it, as long as the HDR image still looks good "
"and the gradients are smooth.\n"
"To avoid brightness fluctuations, it's recommended to not exceed the "
"display's maximum average brightness of %1cd/m²"
msgstr ""
"Configura como brillante “100%” deberea esser le glissator per brillantia "
"normal. Face lo tan brillante como tu jammais lo usa,  usque le imagine HDR "
"ancora sembla bon e le gradientes es lisie.\n"
"Per evitar fluctuactiones de brillantia, iles recommendate non exceder le "
"maxime brillantia medie del monstrator de of %1cd/m²"

#: Main.qml:391
#, kde-format
msgid ""
"Configure how bright “100%” on the normal brightness slider should be. Make "
"it as bright as you'd ever use it, as long as the HDR image still looks good "
"and the gradients are smooth."
msgstr ""
"Configura como brillante “100%” deberea esser le glissator per brillantia "
"normal. Face lo tan brillante como tu jammais lo usa,  usque le imagine HDR "
"ancora sembla bon e le gradientes es lisie."

#: Main.qml:438
#, kde-format
msgid "Maximum luminance: %1cd/m²"
msgstr "Maxime luminantia: %1cd/m²"

#: Main.qml:459
#, kde-format
msgid "Reference luminance / paper white: %1cd/m²"
msgstr "Luminantia de referentia / papiro blanc: %1cd/m²"

#: Main.qml:470
#, kde-format
msgctxt "@action:checkbox"
msgid "Assume Windows HDR applications are calibrated for this screen"
msgstr "Suppone que applicationes de Windows HDR es calibrate per iste schermo"

#: Main.qml:482
#, kde-format
msgctxt "@action:button"
msgid "Done"
msgstr "Facite"

#: Main.qml:491
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Finish the calibration process"
msgstr "Fini le processo de calibration"

#: Main.qml:500
#, kde-format
msgid ""
"Many Windows applications come with their own calibration settings, which "
"this system wide configuration conflicts with. If this option is set, their "
"calibration settings will work as expected on this specific display."
msgstr ""
"Multe applicationes de Windows veni con lor proprie preferentias de "
"calibration, con le quales le large configuration de systema conflige. Si "
"iste option es fixate, lor preferentias de calibration functionara como "
"attendite sur iste specific monstrator."

#~ msgid ""
#~ "To determine the maximum average brightness of the screen, adjust the "
#~ "slider until the logo is barely visible"
#~ msgstr ""
#~ "Per determinar le maxime brillantia medie del schermo, accomoda le "
#~ "glissator usque le logo es apena visibile  "

#~ msgid "Maximum fullscreen luminance: %1cd/m²"
#~ msgstr "Maxime luminantia de schermo plen: %1cd/m²"
