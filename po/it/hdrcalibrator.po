#: hdrcalibrator.cpp:149 Main.qml:15
#, kde-format
msgctxt "@title:window"
msgid "HDR Calibration"
msgstr "Calibrazione HDR"

#: Main.qml:187 Main.qml:365
#, kde-format
msgctxt "@action:button"
msgid "Next"
msgstr "Successivo"

#: Main.qml:194 Main.qml:371
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Switches to the next page"
msgstr "Passa alla pagina successiva"

#: Main.qml:198 Main.qml:375 Main.qml:475
#, kde-format
msgctxt "@action:button"
msgid "Cancel"
msgstr "Annulla"

#: Main.qml:201 Main.qml:378 Main.qml:478
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Cancels the calibration process"
msgstr "Annulla questo processo di calibrazione"

#: Main.qml:210
#, kde-format
msgid ""
"To determine the maximum brightness of the screen, adjust the slider until "
"the logo is barely visible"
msgstr ""
"Per determinare la luminosità massima dello schermo, regola il cursore fino "
"a quando il logo sarà appena visibile"

#: Main.qml:389
#, kde-format
msgid ""
"Configure how bright “100%” on the normal brightness slider should be. Make "
"it as bright as you'd ever use it, as long as the HDR image still looks good "
"and the gradients are smooth.\n"
"To avoid brightness fluctuations, it's recommended to not exceed the "
"display's maximum average brightness of %1cd/m²"
msgstr ""
"Configura quanto dovrebbe essere il \"100%\" del cursore della luminosità "
"normale. Rendilo luminoso come non lo vorresti mai usare, a patto che "
"l'immagine HDR abbia un bell'aspetto e che le sfumature siano uniformi.\n"
"Per evitare fluttuazioni di luminosità, si consiglia di non superare la "
"luminosità media massima dello schermo di %1cd/m²."

#: Main.qml:391
#, kde-format
msgid ""
"Configure how bright “100%” on the normal brightness slider should be. Make "
"it as bright as you'd ever use it, as long as the HDR image still looks good "
"and the gradients are smooth."
msgstr ""
"Configura quanto dovrebbe essere il \"100%\" del cursore della luminosità "
"normale. Rendilo luminoso come non lo vorresti mai usare, a patto che "
"l'immagine HDR abbia un bell'aspetto e che le sfumature siano uniformi."

#: Main.qml:438
#, kde-format
msgid "Maximum luminance: %1cd/m²"
msgstr "Luminanza massima: %1cd/m²"

#: Main.qml:459
#, kde-format
msgid "Reference luminance / paper white: %1cd/m²"
msgstr "Luminanza di riferimento / carta bianca: %1cd/m²"

#: Main.qml:470
#, kde-format
msgctxt "@action:checkbox"
msgid "Assume Windows HDR applications are calibrated for this screen"
msgstr ""
"Supponi che le applicazioni HDR di Windows siano calibrate per questo schermo"

#: Main.qml:482
#, kde-format
msgctxt "@action:button"
msgid "Done"
msgstr "Fatto"

#: Main.qml:491
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Finish the calibration process"
msgstr "Termina il processo di calibrazione"

#: Main.qml:500
#, kde-format
msgid ""
"Many Windows applications come with their own calibration settings, which "
"this system wide configuration conflicts with. If this option is set, their "
"calibration settings will work as expected on this specific display."
msgstr ""
"Molte applicazioni di Windows dispongono di proprie impostazioni di "
"calibrazione, che entrano in conflitto con questa configurazione a livello "
"di sistema. Se questa opzione è attivata, le loro impostazioni di "
"calibrazione funzioneranno come previsto su questo schermo specifico."

#~ msgid ""
#~ "To determine the maximum average brightness of the screen, adjust the "
#~ "slider until the logo is barely visible"
#~ msgstr ""
#~ "Per determinare la luminosità media massima dello schermo, regola il "
#~ "cursore fino a quando il logo sarà appena visibile"

#~ msgid "Maximum fullscreen luminance: %1cd/m²"
#~ msgstr "Luminanza massima a schermo intero: %1cd/m²"
