#: hdrcalibrator.cpp:149 Main.qml:16
#, kde-format
msgctxt "@title:window"
msgid "HDR Calibration"
msgstr "HDR-Kalibrierung"

#: Main.qml:188 Main.qml:366
#, kde-format
msgctxt "@action:button"
msgid "Next"
msgstr "Weiter"

#: Main.qml:195 Main.qml:372
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Switches to the next page"
msgstr "Wechselt zur nächsten Seite"

#: Main.qml:199 Main.qml:376 Main.qml:476
#, kde-format
msgctxt "@action:button"
msgid "Cancel"
msgstr "Abbrechen"

#: Main.qml:202 Main.qml:379 Main.qml:479
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Cancels the calibration process"
msgstr "Bricht den Kablibrierungsprozess ab"

#: Main.qml:211
#, kde-format
msgid ""
"To determine the maximum brightness of the screen, adjust the slider until "
"the logo is barely visible"
msgstr ""
"Um die maximale Helligkeit des Bildschirms festzustellen, verschieben Sie "
"den Schieberegler bis das Logo kaum noch sichtbar ist."

#: Main.qml:390
#, kde-format
msgid ""
"Configure how bright “100%” on the normal brightness slider should be. Make "
"it as bright as you'd ever use it, as long as the HDR image still looks good "
"and the gradients are smooth.\n"
"To avoid brightness fluctuations, it's recommended to not exceed the "
"display's maximum average brightness of %1cd/m²"
msgstr ""
"Helligkeit für „100 %“ am Schieberegler für normale Helligkeit einstellen. "
"Stellen Sie sie so hell ein, wie Sie sie jemals nutzen werden, solange das "
"HDR-Bild gut aussieht und die Verläufe weich sind.\n"
"Um Helligkeitsschwankungen zu vermeiden wird es empfohlen, dass die maximale "
"durchschnittliche Helligkeit der Anzeige von %1 cd/m² nicht überschritten "
"wird"

#: Main.qml:392
#, kde-format
msgid ""
"Configure how bright “100%” on the normal brightness slider should be. Make "
"it as bright as you'd ever use it, as long as the HDR image still looks good "
"and the gradients are smooth."
msgstr ""
"Helligkeit für „100 %“ am Schieberegler für normale Helligkeit einstellen. "
"Stellen Sie sie so hell ein, wie Sie sie jemals nutzen werden, solange das "
"HDR-Bild gut aussieht und die Verläufe weich sind."

#: Main.qml:439
#, kde-format
msgid "Maximum luminance: %1cd/m²"
msgstr "Maximale Leuchtdichte: %1 cd/m²"

#: Main.qml:460
#, kde-format
msgid "Reference luminance / paper white: %1cd/m²"
msgstr "Referenzleuchtdichte / Papierweiß: %1 cd/m²"

#: Main.qml:471
#, kde-format
msgctxt "@action:checkbox"
msgid "Assume Windows HDR applications are calibrated for this screen"
msgstr ""
"Annehmen, dass Windows-HDR-Anwendungen für diesen Bildschirm kalibriert sind"

#: Main.qml:483
#, kde-format
msgctxt "@action:button"
msgid "Done"
msgstr "Fertig"

#: Main.qml:492
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Finish the calibration process"
msgstr "Den Kablibrierungsprozess abschließen"

#: Main.qml:501
#, kde-format
msgid ""
"Many Windows applications come with their own calibration settings, which "
"this system wide configuration conflicts with. If this option is set, their "
"calibration settings will work as expected on this specific display."
msgstr ""
"Viele Windows-Anwendungen verwenden ihre eigenen Kalibrierungseinstellungen, "
"die nicht mit diesen systemweiten Einstellungen vereinbar sind. Wenn diese "
"Option aktiviert ist, werden die Einstellungen solcher Anwendungen auf "
"diesem Bildschirm wie erwartet funktionieren."

#~ msgid ""
#~ "To determine the maximum average brightness of the screen, adjust the "
#~ "slider until the logo is barely visible"
#~ msgstr ""
#~ "Um die maximale durchschnittliche Helligkeit des Bildschirms "
#~ "festzustellen, verschieben Sie den Schieberegler bis das Logo kaum noch "
#~ "sichtbar ist."

#~ msgid "Maximum fullscreen luminance: %1cd/m²"
#~ msgstr "Maximale Vollbild-Leuchtdichte: %1 cd/m²"
