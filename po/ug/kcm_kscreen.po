#: ui/OutputPanel.qml:408
#, kde-kuit-format
msgctxt "@info:tooltip"
msgid ""
"Limits the color resolution of the image that is sent to the display. This "
"does not affect screenshots or recordings.<nl/><nl/>Because the display is "
"currently connected through a dock, automatic color resolution has been "
"temporarily reduced to 8 bits to avoid common dock issues.<nl/><nl/>Due to "
"graphics driver limitations, the actually used resolution cannot be known."
msgstr ""

#: ui/OutputPanel.qml:412
#, kde-kuit-format
msgctxt "@info:tooltip"
msgid ""
"Limits the color resolution of the image that is sent to the display. This "
"does not affect screenshots or recordings.<nl/><nl/>Limiting color "
"resolution can be useful to work around display or graphics driver issues."
"<nl/><nl/>Due to graphics driver limitations, the actually used resolution "
"cannot be known."
msgstr ""

