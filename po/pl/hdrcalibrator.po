#: hdrcalibrator.cpp:149 Main.qml:15
#, kde-format
msgctxt "@title:window"
msgid "HDR Calibration"
msgstr "Kalibracja HDR"

#: Main.qml:187 Main.qml:365
#, kde-format
msgctxt "@action:button"
msgid "Next"
msgstr "Następna"

#: Main.qml:194 Main.qml:371
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Switches to the next page"
msgstr "Przełącza do następnej strony"

#: Main.qml:198 Main.qml:375 Main.qml:475
#, kde-format
msgctxt "@action:button"
msgid "Cancel"
msgstr "Anuluj"

#: Main.qml:201 Main.qml:378 Main.qml:478
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Cancels the calibration process"
msgstr "Przerywa kalibrację"

#: Main.qml:210
#, kde-format
msgid ""
"To determine the maximum brightness of the screen, adjust the slider until "
"the logo is barely visible"
msgstr ""
"Aby ustalić najwyższą jasność ekranu, przesuwaj suwakiem, aż logo będzie "
"ledwo widoczne"

#: Main.qml:389
#, fuzzy, kde-format
#| msgid ""
#| "Configure how bright \"100%\" on the normal brightness slider should be. "
#| "Make it as bright as you'd ever use it, as long as the HDR image still "
#| "looks good and the gradients are smooth.\n"
#| "To avoid brightness fluctuations, it's recommended to not exceed the "
#| "display's maximum average brightness of %1cd/m²"
msgid ""
"Configure how bright “100%” on the normal brightness slider should be. Make "
"it as bright as you'd ever use it, as long as the HDR image still looks good "
"and the gradients are smooth.\n"
"To avoid brightness fluctuations, it's recommended to not exceed the "
"display's maximum average brightness of %1cd/m²"
msgstr ""
"Ustaw jak jasne \"100%\" będzie na normalnym suwaku jasności. Uczyń je tak "
"jasnym jakim kiedykolwiek ma być przy zapewnieniu, że obraz HDR nadal "
"wygląda dobrze, a gradienty są nadal gładkie.\n"
"Aby uniknąć miejscowych zmian jasności, zalecamy nieprzekraczanie najwyższej "
"przeciętnej jasności wyświetlacza równej %1cd/m²"

#: Main.qml:391
#, fuzzy, kde-format
#| msgid ""
#| "Configure how bright \"100%\" on the normal brightness slider should be. "
#| "Make it as bright as you'd ever use it, as long as the HDR image still "
#| "looks good and the gradients are smooth.\n"
#| "To avoid brightness fluctuations, it's recommended to not exceed the "
#| "display's maximum average brightness of %1cd/m²"
msgid ""
"Configure how bright “100%” on the normal brightness slider should be. Make "
"it as bright as you'd ever use it, as long as the HDR image still looks good "
"and the gradients are smooth."
msgstr ""
"Ustaw jak jasne \"100%\" będzie na normalnym suwaku jasności. Uczyń je tak "
"jasnym jakim kiedykolwiek ma być przy zapewnieniu, że obraz HDR nadal "
"wygląda dobrze, a gradienty są nadal gładkie.\n"
"Aby uniknąć miejscowych zmian jasności, zalecamy nieprzekraczanie najwyższej "
"przeciętnej jasności wyświetlacza równej %1cd/m²"

#: Main.qml:438
#, kde-format
msgid "Maximum luminance: %1cd/m²"
msgstr "Najwyższa luminancja: %1cd/m²"

#: Main.qml:459
#, kde-format
msgid "Reference luminance / paper white: %1cd/m²"
msgstr "Luminancja odniesienia / biała kartka papieru: %1cd/m²"

#: Main.qml:470
#, kde-format
msgctxt "@action:checkbox"
msgid "Assume Windows HDR applications are calibrated for this screen"
msgstr "Załóż, że aplikacje HDR z Windowsa są skalibrowane dla tego ekranu"

#: Main.qml:482
#, kde-format
msgctxt "@action:button"
msgid "Done"
msgstr "Gotowe"

#: Main.qml:491
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Finish the calibration process"
msgstr "Ukończ kalibrację"

#: Main.qml:500
#, kde-format
msgid ""
"Many Windows applications come with their own calibration settings, which "
"this system wide configuration conflicts with. If this option is set, their "
"calibration settings will work as expected on this specific display."
msgstr ""
"Wiele aplikacji na Windowsie dostarcza własnych ustawień kalibracji, z "
"którymi ustawienia systemowe się gryzą. Po zaznaczeniu tego pola, ich "
"ustawienia kalibracji będą działać zgodnie z oczekiwaniami na tym "
"wyświetlaczu."

#~ msgid ""
#~ "To determine the maximum average brightness of the screen, adjust the "
#~ "slider until the logo is barely visible"
#~ msgstr ""
#~ "Aby ustalić najwyższą przeciętną jasność ekranu, przesuwaj suwakiem, aż "
#~ "logo będzie ledwo widoczne"

#~ msgid "Maximum fullscreen luminance: %1cd/m²"
#~ msgstr "Najwyższa luminancja na całym ekranie: %1cd/m²"
