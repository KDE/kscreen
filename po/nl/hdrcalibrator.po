#: hdrcalibrator.cpp:149 Main.qml:15
#, kde-format
msgctxt "@title:window"
msgid "HDR Calibration"
msgstr "HDR-kalibratie"

#: Main.qml:187 Main.qml:365
#, kde-format
msgctxt "@action:button"
msgid "Next"
msgstr "Volgende"

#: Main.qml:194 Main.qml:371
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Switches to the next page"
msgstr "Schakelt over naar de volgende pagina"

#: Main.qml:198 Main.qml:375 Main.qml:475
#, kde-format
msgctxt "@action:button"
msgid "Cancel"
msgstr "Annuleren"

#: Main.qml:201 Main.qml:378 Main.qml:478
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Cancels the calibration process"
msgstr "Annuleert het kalibratieproces"

#: Main.qml:210
#, kde-format
msgid ""
"To determine the maximum brightness of the screen, adjust the slider until "
"the logo is barely visible"
msgstr ""
"Om de maximale helderheid van het scherm te bepalen, pas de schuifregelaar "
"aan totdat het logo nauwelijks zichtbaar is"

#: Main.qml:389
#, kde-format
msgid ""
"Configure how bright “100%” on the normal brightness slider should be. Make "
"it as bright as you'd ever use it, as long as the HDR image still looks good "
"and the gradients are smooth.\n"
"To avoid brightness fluctuations, it's recommended to not exceed the "
"display's maximum average brightness of %1cd/m²"
msgstr ""
"Configureer hoe helder “100%” op de schuifregelaar voor normale helderheid "
"zou moeten zijn. Maak het zo helder als u het ooit zou gebruiken, zolang de "
"HDR-afbeelding er nog steeds goed uitziet en het kleurverloop gladjes is.\n"
"Om helderheidsfluctuaties te vermijden, wordt het aanbevolen niet de "
"maximale gemiddelde helderheid van %1cd/m² van het scherm te overschrijden."

#: Main.qml:391
#, kde-format
msgid ""
"Configure how bright “100%” on the normal brightness slider should be. Make "
"it as bright as you'd ever use it, as long as the HDR image still looks good "
"and the gradients are smooth."
msgstr ""
"Configureer hoe helder “100%” op de schuifregelaar voor normale helderheid "
"zou moeten zijn. Maak het zo helder als u het ooit zou gebruiken, zolang de "
"HDR-afbeelding er nog steeds goed uitziet en het kleurverloop gladjes is."

#: Main.qml:438
#, kde-format
msgid "Maximum luminance: %1cd/m²"
msgstr "Maximale lichtkracht: %1cd/m²"

#: Main.qml:459
#, kde-format
msgid "Reference luminance / paper white: %1cd/m²"
msgstr "Referentie lichtkracht / papierwit: %1cd/m²"

#: Main.qml:470
#, kde-format
msgctxt "@action:checkbox"
msgid "Assume Windows HDR applications are calibrated for this screen"
msgstr ""
"Neem aan dat toepassingen voor Windows HDR gekalibreerd zijn voor dit scherm"

#: Main.qml:482
#, kde-format
msgctxt "@action:button"
msgid "Done"
msgstr "Gereed"

#: Main.qml:491
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Finish the calibration process"
msgstr "Beëindig het kalibratieproces"

#: Main.qml:500
#, kde-format
msgid ""
"Many Windows applications come with their own calibration settings, which "
"this system wide configuration conflicts with. If this option is set, their "
"calibration settings will work as expected on this specific display."
msgstr ""
"Veel toepassingen voor Windows komen met hun eigen instellingen voor "
"kalibratie, waarmee deze configuratie systeembreed conflicteert. Als deze "
"optie is geactiveerd, zullen hun kalibratie-instellingen werken zoals "
"verwacht op dit specifieke scherm."

#~ msgid ""
#~ "To determine the maximum average brightness of the screen, adjust the "
#~ "slider until the logo is barely visible"
#~ msgstr ""
#~ "Om de maximale gemiddelde helderheid van het scherm te bepalen, pas de "
#~ "schuifregelaar aan totdat het logo nauwelijks zichtbaar is"

#~ msgid "Maximum fullscreen luminance: %1cd/m²"
#~ msgstr "Maximale lichtkracht van volledig scherm: %1cd/m²"
