#: hdrcalibrator.cpp:149 Main.qml:16
#, kde-format
msgctxt "@title:window"
msgid "HDR Calibration"
msgstr "HDR Kalibrasyonu"

#: Main.qml:188 Main.qml:366
#, kde-format
msgctxt "@action:button"
msgid "Next"
msgstr "Sonraki"

#: Main.qml:195 Main.qml:372
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Switches to the next page"
msgstr "Sonraki sayfaya geçer"

#: Main.qml:199 Main.qml:376 Main.qml:476
#, kde-format
msgctxt "@action:button"
msgid "Cancel"
msgstr "İptal"

#: Main.qml:202 Main.qml:379 Main.qml:479
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Cancels the calibration process"
msgstr "Kalibrasyon sürecini iptal eder"

#: Main.qml:211
#, kde-format
msgid ""
"To determine the maximum brightness of the screen, adjust the slider until "
"the logo is barely visible"
msgstr ""
"Ekranın en yüksek parlaklığını algılamak için logo neredeyse görünmez olana "
"değin sürgüyü sürün."

#: Main.qml:390
#, kde-format
msgid ""
"Configure how bright “100%” on the normal brightness slider should be. Make "
"it as bright as you'd ever use it, as long as the HDR image still looks good "
"and the gradients are smooth.\n"
"To avoid brightness fluctuations, it's recommended to not exceed the "
"display's maximum average brightness of %1cd/m²"
msgstr ""
"Normal parlaklık sürgüsündeki “%​100” değerinin ne kadar parlak olması "
"gerektiğini yapılandırın. Onu, HDR görsel hâlâ düzgünce görünür ve "
"gradyanlar pürüzsüz kalana değin kullanacağınız en parlak düzeye getirin.\n"
"Parlaklık dalgalanmalarından kaçınmak için ekranın en yüksek ortalama "
"parlaklığı olan %1 cd/m² değerinin aşılmaması önerilir."

#: Main.qml:392
#, kde-format
msgid ""
"Configure how bright “100%” on the normal brightness slider should be. Make "
"it as bright as you'd ever use it, as long as the HDR image still looks good "
"and the gradients are smooth."
msgstr ""
"Normal parlaklık sürgüsündeki “%​100” değerinin ne kadar parlak olması "
"gerektiğini yapılandırın. Onu, HDR görsel hâlâ düzgünce görünür ve "
"gradyanlar pürüzsüz kalana değin kullanacağınız en parlak düzeye getirin."

#: Main.qml:439
#, kde-format
msgid "Maximum luminance: %1cd/m²"
msgstr "En yüksek aydınlık %1 cd/m²"

#: Main.qml:460
#, kde-format
msgid "Reference luminance / paper white: %1cd/m²"
msgstr "Başvurulan aydınlık / beyaz kâğıt: %1 cd/m²"

#: Main.qml:471
#, kde-format
msgctxt "@action:checkbox"
msgid "Assume Windows HDR applications are calibrated for this screen"
msgstr "Windows HDR uygulamalarının bu ekrana göre kalibre edildiğini varsay"

#: Main.qml:483
#, kde-format
msgctxt "@action:button"
msgid "Done"
msgstr "Bitti"

#: Main.qml:492
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Finish the calibration process"
msgstr "Kalibrasyon sürecini bitir"

#: Main.qml:501
#, kde-format
msgid ""
"Many Windows applications come with their own calibration settings, which "
"this system wide configuration conflicts with. If this option is set, their "
"calibration settings will work as expected on this specific display."
msgstr ""
"Birçok Windows uygulaması, bu sistem genelindeki yapılandırmayla çakışan "
"kendi kalibrasyon ayarlarıyla birlikte gelir. Bu seçenek ayarlanırsa "
"kalibrasyon ayarları bu belirli ekrandan beklendiği gibi çalışacaktır."

#~ msgid ""
#~ "To determine the maximum average brightness of the screen, adjust the "
#~ "slider until the logo is barely visible"
#~ msgstr ""
#~ "Ekranın en yüksek ortalama parlaklığını algılamak için logo neredeyse "
#~ "görünmez olana dek sürgüyü sürün."

#~ msgid "Maximum fullscreen luminance: %1cd/m²"
#~ msgstr "En yüksek tam ekran aydınlığı: %1 cd/m²"
