#: hdrcalibrator.cpp:149 Main.qml:15
#, kde-format
msgctxt "@title:window"
msgid "HDR Calibration"
msgstr "Calibração HDR"

#: Main.qml:187 Main.qml:365
#, kde-format
msgctxt "@action:button"
msgid "Next"
msgstr "Próximo"

#: Main.qml:194 Main.qml:371
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Switches to the next page"
msgstr "Alterna para a próxima página"

#: Main.qml:198 Main.qml:375 Main.qml:475
#, kde-format
msgctxt "@action:button"
msgid "Cancel"
msgstr "Cancelar"

#: Main.qml:201 Main.qml:378 Main.qml:478
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Cancels the calibration process"
msgstr "Cancela o processo de calibração"

#: Main.qml:210
#, kde-format
msgid ""
"To determine the maximum brightness of the screen, adjust the slider until "
"the logo is barely visible"
msgstr ""
"Para determinar o brilho máximo da tela, ajuste o controle deslizante até "
"que o logotipo quase não esteja visível"

#: Main.qml:389
#, kde-format
msgid ""
"Configure how bright “100%” on the normal brightness slider should be. Make "
"it as bright as you'd ever use it, as long as the HDR image still looks good "
"and the gradients are smooth.\n"
"To avoid brightness fluctuations, it's recommended to not exceed the "
"display's maximum average brightness of %1cd/m²"
msgstr ""
"Configure o quão brilhante deve ser o “100%“ no controle deslizante de "
"brilho normal. Ajuste para o nível mais brilhante que você usaria, desde que "
"a imagem em HDR ainda pareça boa e os degradês estejam suaves.\n"
"Para evitar flutuações de brilho, recomenda-se não exceder o brilho médio "
"máximo do monitor de %1 cd/m²"

#: Main.qml:391
#, kde-format
msgid ""
"Configure how bright “100%” on the normal brightness slider should be. Make "
"it as bright as you'd ever use it, as long as the HDR image still looks good "
"and the gradients are smooth."
msgstr ""
"Configure o quão brilhante deve ser o “100%“ no controle deslizante de "
"brilho normal. Ajuste para o nível mais brilhante que você usaria, desde que "
"a imagem em HDR ainda pareça boa e os degradês estejam suaves."

#: Main.qml:438
#, kde-format
msgid "Maximum luminance: %1cd/m²"
msgstr "Luminância máxima: %1cd/m²"

#: Main.qml:459
#, kde-format
msgid "Reference luminance / paper white: %1cd/m²"
msgstr "Luminância de referência / branco do papel: %1cd/m²"

#: Main.qml:470
#, kde-format
msgctxt "@action:checkbox"
msgid "Assume Windows HDR applications are calibrated for this screen"
msgstr ""
"Supor que os aplicativos HDR do Windows estejam calibrados para esta tela"

#: Main.qml:482
#, kde-format
msgctxt "@action:button"
msgid "Done"
msgstr "Concluído"

#: Main.qml:491
#, kde-format
msgctxt "@info accessible description of a push button"
msgid "Finish the calibration process"
msgstr "Terminar o processo de calibração"

#: Main.qml:500
#, kde-format
msgid ""
"Many Windows applications come with their own calibration settings, which "
"this system wide configuration conflicts with. If this option is set, their "
"calibration settings will work as expected on this specific display."
msgstr ""
"Muitos aplicativos do Windows vêm com suas próprias configurações de "
"calibração, com as quais a configuração do sistema entra em conflito. Se "
"esta opção estiver ativada, as configurações de calibração funcionarão "
"conforme o esperado nesta tela específica."

#~ msgid ""
#~ "To determine the maximum average brightness of the screen, adjust the "
#~ "slider until the logo is barely visible"
#~ msgstr ""
#~ "Para determinar o brilho médio máximo da tela, ajuste o controle "
#~ "deslizante até que o logotipo quase não esteja visível"

#~ msgid "Maximum fullscreen luminance: %1cd/m²"
#~ msgstr "Luminância máxima em tela cheia: %1cd/m²"
